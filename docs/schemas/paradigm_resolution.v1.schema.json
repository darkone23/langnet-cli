{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langnet.local/schemas/paradigm_resolution.v1.schema.json",
  "title": "LangNet paradigm resolution response",
  "type": "object",
  "required": [
    "schema_version",
    "searched_form",
    "normalized_form",
    "language",
    "candidates",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "langnet.paradigm_resolution.v1" },
    "searched_form": { "type": "string" },
    "normalized_form": { "type": "string" },
    "language": { "enum": ["lat", "grc", "san"] },
    "candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidate" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "lemma",
        "entry_type",
        "part_of_speech",
        "paradigm_kind",
        "observed_form",
        "slot_features",
        "foster_display",
        "display_summary",
        "ranking_reasons",
        "concept_ids",
        "native_analyses",
        "functional_analyses",
        "paradigm_request",
        "confidence",
        "provenance",
        "unresolved_reason"
      ],
      "properties": {
        "lemma": { "type": "string" },
        "entry_type": { "enum": ["root", "variant", "indeclinable", "compound_member", "unknown"] },
        "part_of_speech": { "type": "string" },
        "paradigm_kind": { "enum": ["declension", "conjugation", "none", "unknown"] },
        "observed_form": { "type": ["string", "null"] },
        "slot_features": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        },
        "foster_display": { "type": "string" },
        "display_summary": { "type": ["string", "null"] },
        "ranking_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "learning_overlay": { "$ref": "#/$defs/learningOverlay" },
        "native_analyses": {
          "type": "array",
          "items": { "$ref": "#/$defs/nativeAnalysis" }
        },
        "functional_analyses": {
          "type": "array",
          "items": { "$ref": "#/$defs/functionalAnalysis" }
        },
        "paradigm_request": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/paradigmRequest" }
          ]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "provenance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unresolved_reason": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "learningOverlay": {
      "type": "object",
      "required": ["schema_version", "status", "concept_ids", "concepts", "missing_evidence"],
      "properties": {
        "schema_version": { "const": "langnet.learning_overlay.v1" },
        "status": { "enum": ["mapped", "unmapped"] },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concepts": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningConcept" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningEvidenceGap" }
        }
      },
      "additionalProperties": false
    },
    "learningEvidenceGap": {
      "type": "object",
      "required": ["concept_id", "missing"],
      "properties": {
        "concept_id": { "type": ["string", "null"] },
        "missing": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "sourceEvidence": {
      "type": "object",
      "required": [
        "evidence_level",
        "source_anchor_id",
        "work_id",
        "canonical_text_id",
        "cts_work_urn",
        "citation_path",
        "canonical_address",
        "label"
      ],
      "properties": {
        "evidence_level": { "enum": ["reader_work", "reader_segment"] },
        "source_anchor_id": { "type": "string" },
        "work_id": { "type": "string" },
        "canonical_text_id": { "type": "string" },
        "cts_work_urn": { "type": ["string", "null"] },
        "citation_path": { "type": ["string", "null"] },
        "canonical_address": { "type": ["string", "null"] },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "learningConcept": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "foster_gateway",
        "plain_english",
        "traditional",
        "native_gateways",
        "source_evidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "foster_gateway": { "type": "string" },
        "plain_english": { "type": "string" },
        "traditional": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "native_gateways": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningNativeGateway" }
        },
        "source_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceEvidence" }
        },
        "foster_bridges": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningFosterBridge" }
        }
      },
      "additionalProperties": false
    },
    "learningNativeGateway": {
      "type": "object",
      "required": ["language", "label", "term", "role", "foster_gateway", "explanation"],
      "properties": {
        "language": { "enum": ["grc", "lat", "san"] },
        "label": { "type": "string" },
        "term": { "type": "string" },
        "role": { "type": "string" },
        "foster_gateway": { "type": "string" },
        "explanation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "learningFosterBridge": {
      "type": "object",
      "required": [
        "id",
        "status",
        "foster_terms",
        "concept_ids",
        "related_concept_ids",
        "plain_english",
        "learner_action",
        "product_use",
        "morphology_predicates",
        "source_refs"
      ],
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "foster_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "plain_english": { "type": "string" },
        "learner_action": { "type": "string" },
        "product_use": { "type": "string" },
        "morphology_predicates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "caveats": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "nativeAnalysis": {
      "type": "object",
      "required": ["language", "features", "source"],
      "properties": {
        "language": { "enum": ["lat", "grc", "san"] },
        "features": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        },
        "source": { "type": "string" }
      },
      "additionalProperties": false
    },
    "functionalAnalysis": {
      "type": "object",
      "required": ["relation", "native_feature", "confidence"],
      "properties": {
        "relation": {
          "enum": [
            "subject",
            "direct_object",
            "recipient_or_goal",
            "source_or_separation",
            "possession_or_association",
            "location",
            "instrument_or_means",
            "address",
            "predicate_relation",
            "unknown"
          ]
        },
        "native_feature": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        },
        "confidence": { "enum": ["high", "medium", "low"] }
      },
      "additionalProperties": false
    },
    "paradigmRequest": {
      "type": "object",
      "required": ["source", "language", "lemma", "kind", "options"],
      "properties": {
        "source": { "enum": ["heritage:sktdeclin", "heritage:sktconjug", "diogenes:inflect"] },
        "language": { "enum": ["lat", "grc", "san"] },
        "lemma": { "type": "string" },
        "kind": { "enum": ["declension", "conjugation"] },
        "options": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
