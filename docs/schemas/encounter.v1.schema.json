{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langnet.local/schemas/encounter.v1.schema.json",
  "title": "LangNet encounter success response",
  "type": "object",
  "required": [
    "schema_version",
    "query",
    "language",
    "lexeme_anchors",
    "buckets",
    "warnings",
    "request",
    "display",
    "ranking",
    "translation_cache"
  ],
  "properties": {
    "schema_version": { "const": "langnet.encounter.v1" },
    "query": { "type": "string" },
    "language": { "type": "string" },
    "lexeme_anchors": { "type": "array", "items": { "type": "string" } },
    "buckets": {
      "type": "array",
      "items": { "$ref": "#/$defs/bucket" }
    },
    "unbucketed_witnesses": {
      "type": "array",
      "items": { "$ref": "#/$defs/witness" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "request": { "$ref": "#/$defs/request" },
    "display": { "$ref": "#/$defs/display" },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    },
    "ranking": {
      "type": "array",
      "items": { "type": "object" },
      "additionalItems": true
    },
    "translation_cache": { "type": "object" },
    "word_index": { "$ref": "#/$defs/wordIndexContext" },
    "paradigm_resolution": { "$ref": "#/$defs/paradigmResolution" },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/encounterAction" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "request": {
      "type": "object",
      "required": [
        "language",
        "text",
        "tool_filter",
        "normalize",
        "no_cache",
        "cache_policy",
        "normalization_cache_writes",
        "include_cltk",
        "translation_mode",
        "translation_cache_writes",
        "include_paradigm_resolution",
        "include_learning"
      ],
      "properties": {
        "command": { "type": "string" },
        "language": { "type": "string" },
        "text": { "type": "string" },
        "tool_filter": { "type": "string" },
        "normalize": { "type": "boolean" },
        "no_cache": { "type": "boolean" },
        "cache_policy": { "type": "string" },
        "normalization_cache_writes": { "type": "boolean" },
        "include_cltk": { "type": "boolean" },
        "translation_mode": { "type": "string" },
        "translation_cache_writes": { "type": "boolean" },
        "debug": { "type": "boolean" },
        "show_candidates": { "type": "boolean" },
        "show_ranking": { "type": "boolean" },
        "show_source": { "type": "boolean" },
        "include_paradigm_resolution": { "type": "boolean" },
        "include_learning": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "paradigmResolution": {
      "type": "object",
      "required": [
        "schema_version",
        "searched_form",
        "normalized_form",
        "language",
        "candidates",
        "warnings"
      ],
      "properties": {
        "schema_version": { "const": "langnet.paradigm_resolution.v1" },
        "searched_form": { "type": "string" },
        "normalized_form": { "type": "string" },
        "language": { "enum": ["lat", "grc", "san"] },
        "candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/paradigmResolutionCandidate" }
        },
        "warnings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "paradigmResolutionCandidate": {
      "type": "object",
      "properties": {
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "learning_overlay": { "$ref": "#/$defs/learningOverlay" }
      },
      "additionalProperties": true
    },
    "learningOverlay": {
      "type": "object",
      "required": ["schema_version", "status", "concept_ids", "concepts", "missing_evidence"],
      "properties": {
        "schema_version": { "const": "langnet.learning_overlay.v1" },
        "status": { "enum": ["mapped", "unmapped"] },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concepts": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningConcept" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningEvidenceGap" }
        }
      },
      "additionalProperties": false
    },
    "learningEvidenceGap": {
      "type": "object",
      "required": ["concept_id", "missing"],
      "properties": {
        "concept_id": { "type": ["string", "null"] },
        "missing": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "sourceEvidence": {
      "type": "object",
      "required": [
        "evidence_level",
        "source_anchor_id",
        "work_id",
        "canonical_text_id",
        "cts_work_urn",
        "citation_path",
        "canonical_address",
        "label"
      ],
      "properties": {
        "evidence_level": { "enum": ["reader_work", "reader_segment"] },
        "source_anchor_id": { "type": "string" },
        "work_id": { "type": "string" },
        "canonical_text_id": { "type": "string" },
        "cts_work_urn": { "type": ["string", "null"] },
        "citation_path": { "type": ["string", "null"] },
        "canonical_address": { "type": ["string", "null"] },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    },
    "learningConcept": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "foster_gateway",
        "plain_english",
        "traditional",
        "native_gateways",
        "source_evidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "foster_gateway": { "type": "string" },
        "plain_english": { "type": "string" },
        "traditional": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "native_gateways": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningNativeGateway" }
        },
        "source_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceEvidence" }
        },
        "foster_bridges": {
          "type": "array",
          "items": { "$ref": "#/$defs/learningFosterBridge" }
        }
      },
      "additionalProperties": false
    },
    "learningNativeGateway": {
      "type": "object",
      "required": ["language", "label", "term", "role", "foster_gateway", "explanation"],
      "properties": {
        "language": { "enum": ["grc", "lat", "san"] },
        "label": { "type": "string" },
        "term": { "type": "string" },
        "role": { "type": "string" },
        "foster_gateway": { "type": "string" },
        "explanation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "learningFosterBridge": {
      "type": "object",
      "required": [
        "id",
        "status",
        "foster_terms",
        "concept_ids",
        "related_concept_ids",
        "plain_english",
        "learner_action",
        "product_use",
        "morphology_predicates",
        "source_refs"
      ],
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "foster_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_concept_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "plain_english": { "type": "string" },
        "learner_action": { "type": "string" },
        "product_use": { "type": "string" },
        "morphology_predicates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "caveats": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "display": {
      "type": "object",
      "required": ["header", "analysis", "meanings", "options"],
      "properties": {
        "header": { "$ref": "#/$defs/header" },
        "analysis": {
          "type": "array",
          "items": { "$ref": "#/$defs/analysisRow" }
        },
        "meanings": {
          "type": "array",
          "items": { "$ref": "#/$defs/meaningRow" }
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" }
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/encounterAction" }
        },
        "options": {
          "type": "object",
          "required": ["max_gloss_chars", "foster_labels", "source_details"],
          "properties": {
            "max_gloss_chars": { "type": "integer" },
            "foster_labels": { "type": "boolean" },
            "source_details": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "encounterAction": {
      "type": "object",
      "required": ["kind", "label", "status", "source", "request"],
      "properties": {
        "kind": {
          "enum": [
            "view_paradigm",
            "open_word_index_neighborhood",
            "inspect_source_entry",
            "search_reader_corpus"
          ]
        },
        "label": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "request": { "type": "object" },
        "target": { "type": "object" }
      },
      "additionalProperties": true
    },
    "header": {
      "type": "object",
      "required": ["forms", "source_keys"],
      "properties": {
        "forms": { "type": "array", "items": { "type": "string" } },
        "source_keys": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "analysisRow": {
      "type": "object",
      "required": ["form", "lemma", "analysis", "source", "foster_display", "display_text"],
      "properties": {
        "form": { "type": "string" },
        "lemma": { "type": "string" },
        "analysis": { "type": "string" },
        "source": { "type": "string" },
        "foster_display": { "type": "string" },
        "display_text": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meaningRow": {
      "type": "object",
      "required": [
        "bucket_id",
        "display_gloss",
        "evidence_gloss",
        "sources",
        "source_text",
        "witness_count",
        "confidence_label",
        "source_refs",
        "source_detail_summary",
        "translation_sources",
        "source_langs",
        "entries"
      ],
      "properties": {
        "bucket_id": { "type": "string" },
        "display_gloss": { "type": "string" },
        "evidence_gloss": { "type": "string" },
        "evidence_length_note": { "type": "string" },
        "length_note": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "source_text": { "type": "string" },
        "witness_count": { "type": "integer" },
        "confidence_label": { "type": "string" },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "source_detail_summary": { "$ref": "#/$defs/sourceDetailSummary" },
        "translation_sources": { "type": "array", "items": { "type": "string" } },
        "source_langs": { "type": "array", "items": { "type": "string" } },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entrySummary" }
        }
      },
      "additionalProperties": true
    },
    "component": {
      "type": "object",
      "required": [
        "surface",
        "lemma",
        "display",
        "role",
        "analysis",
        "source_tool",
        "lookup_terms",
        "evidence"
      ],
      "properties": {
        "surface": { "type": "string" },
        "lemma": { "type": "string" },
        "display": { "type": "string" },
        "role": { "type": "string" },
        "analysis": { "type": "string" },
        "source_tool": { "type": "string" },
        "lookup_terms": { "type": "array", "items": { "type": "string" } },
        "evidence": { "$ref": "#/$defs/componentEvidence" }
      },
      "additionalProperties": true
    },
    "componentEvidence": {
      "type": "object",
      "required": ["status", "source", "lookup_tool_filter", "meanings", "error"],
      "properties": {
        "status": { "type": "string" },
        "source": { "type": "string" },
        "lookup_tool_filter": { "type": "string" },
        "meanings": {
          "type": "array",
          "items": { "$ref": "#/$defs/componentMeaning" }
        },
        "error": { "type": "string" }
      },
      "additionalProperties": true
    },
    "componentMeaning": {
      "type": "object",
      "required": [
        "bucket_id",
        "display_gloss",
        "evidence_gloss",
        "sources",
        "source_text",
        "witness_count",
        "confidence_label",
        "source_refs",
        "source_detail_summary",
        "translation_sources",
        "source_langs",
        "entries"
      ],
      "properties": {
        "bucket_id": { "type": "string" },
        "display_gloss": { "type": "string" },
        "evidence_gloss": { "type": "string" },
        "evidence_length_note": { "type": "string" },
        "length_note": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "source_text": { "type": "string" },
        "witness_count": { "type": "integer" },
        "confidence_label": { "type": "string" },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "source_detail_summary": { "$ref": "#/$defs/sourceDetailSummary" },
        "translation_sources": { "type": "array", "items": { "type": "string" } },
        "source_langs": { "type": "array", "items": { "type": "string" } },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entrySummary" }
        }
      },
      "additionalProperties": true
    },
    "entrySummary": {
      "type": "object",
      "required": [
        "witness_id",
        "lexeme_anchor",
        "sense_anchor",
        "claim_id",
        "source_tool",
        "source_ref",
        "source_lang",
        "gloss_lang",
        "display_form",
        "source_key",
        "headword",
        "entry_id",
        "dictionary",
        "raw_blob_ref",
        "source_encoding",
        "source_entry",
        "source_detail_summary",
        "translation"
      ],
      "properties": {
        "witness_id": { "type": "string" },
        "lexeme_anchor": { "type": "string" },
        "sense_anchor": { "type": "string" },
        "claim_id": { "type": "string" },
        "source_tool": { "type": "string" },
        "source_ref": { "type": "string" },
        "source_lang": { "type": "string" },
        "gloss_lang": { "type": "string" },
        "display_form": { "type": "string" },
        "source_key": { "type": "string" },
        "headword": { "type": "string" },
        "entry_id": { "type": "string" },
        "dictionary": { "type": "string" },
        "raw_blob_ref": { "type": "string" },
        "source_encoding": { "type": "string" },
        "source_layer_text": { "type": "string" },
        "reader_layer_text": { "type": "string" },
        "source_entry": { "type": "object" },
        "source_detail_summary": { "$ref": "#/$defs/sourceDetailSummary" },
        "translation": { "$ref": "#/$defs/translationSummary" }
      },
      "additionalProperties": true
    },
    "translationSummary": {
      "type": "object",
      "required": [
        "available",
        "translation_id",
        "source_lexicon",
        "source_text_lang",
        "target_lang",
        "model",
        "source_text_hash",
        "derived_from_tool",
        "derived_from_sense"
      ],
      "properties": {
        "available": { "type": "boolean" },
        "translation_id": { "type": "string" },
        "source_lexicon": { "type": "string" },
        "source_text_lang": { "type": "string" },
        "target_lang": { "type": "string" },
        "model": { "type": "string" },
        "source_text_hash": { "type": "string" },
        "derived_from_tool": { "type": "string" },
        "derived_from_sense": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sourceDetailSummary": {
      "type": "object",
      "required": ["cross_refs", "source_refs", "examples", "text"],
      "properties": {
        "cross_refs": { "type": "array", "items": { "type": "string" } },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "examples": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" }
      },
      "additionalProperties": true
    },
    "wordIndexContext": {
      "type": "object",
      "required": [
        "request",
        "primary_result_contiguity",
        "lookup_strategy",
        "anchors",
        "warnings"
      ],
      "properties": {
        "request": { "type": "object" },
        "primary_result_contiguity": {
          "type": "object",
          "required": ["scope", "contiguous", "reason"],
          "properties": {
            "scope": { "const": "encounter_sense_buckets" },
            "contiguous": { "const": false },
            "reason": { "type": "string" }
          },
          "additionalProperties": true
        },
        "lookup_strategy": {
          "type": "object",
          "required": ["inline_window_entries"],
          "properties": {
            "inline_window_entries": { "const": false },
            "source_neighborhood_command": { "type": "string" },
            "wheel_neighborhood_status": { "type": "string" }
          },
          "additionalProperties": true
        },
        "anchors": {
          "type": "array",
          "items": { "$ref": "#/$defs/wordIndexAnchor" }
        },
        "warnings": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "wordIndexAnchor": {
      "type": "object",
      "required": [
        "language",
        "query",
        "source",
        "dictionary",
        "anchor_status",
        "lexeme_id",
        "wheel_id",
        "wheel_order_key",
        "canonical_name",
        "canonical_key",
        "source_name",
        "source_ref",
        "index_entry_id",
        "source_order_id",
        "source_order_key",
        "window"
      ],
      "properties": {
        "language": { "type": "string" },
        "query": { "type": "string" },
        "source": { "type": "string" },
        "dictionary": { "type": "string" },
        "anchor_status": { "type": "string" },
        "lexeme_id": { "type": "string" },
        "wheel_id": { "type": "string" },
        "wheel_order_key": { "type": "string" },
        "canonical_name": { "type": "string" },
        "canonical_key": { "type": "string" },
        "source_name": { "type": "string" },
        "source_ref": { "type": "string" },
        "index_entry_id": { "type": "string" },
        "source_order_id": { "type": "string" },
        "source_order_key": { "type": "string" },
        "window": { "type": "object" }
      },
      "additionalProperties": true
    },
    "bucket": {
      "type": "object",
      "required": ["bucket_id", "normalized_gloss", "display_gloss", "witnesses"],
      "properties": {
        "bucket_id": { "type": "string" },
        "normalized_gloss": { "type": "string" },
        "display_gloss": { "type": "string" },
        "witnesses": {
          "type": "array",
          "items": { "$ref": "#/$defs/witness" }
        }
      },
      "additionalProperties": true
    },
    "witness": {
      "type": "object",
      "required": ["wsu_id", "lexeme_anchor", "sense_anchor", "gloss", "source_tool", "evidence"],
      "properties": {
        "wsu_id": { "type": "string" },
        "lexeme_anchor": { "type": "string" },
        "sense_anchor": { "type": "string" },
        "gloss": { "type": "string" },
        "source_tool": { "type": "string" },
        "evidence": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
