{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langnet.local/schemas/encounter.v1.schema.json",
  "title": "LangNet encounter success response",
  "type": "object",
  "required": [
    "schema_version",
    "query",
    "language",
    "lexeme_anchors",
    "buckets",
    "warnings",
    "request",
    "display",
    "ranking",
    "translation_cache"
  ],
  "properties": {
    "schema_version": { "const": "langnet.encounter.v1" },
    "query": { "type": "string" },
    "language": { "type": "string" },
    "lexeme_anchors": { "type": "array", "items": { "type": "string" } },
    "buckets": {
      "type": "array",
      "items": { "$ref": "#/$defs/bucket" }
    },
    "unbucketed_witnesses": {
      "type": "array",
      "items": { "$ref": "#/$defs/witness" }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "request": { "$ref": "#/$defs/request" },
    "display": { "$ref": "#/$defs/display" },
    "ranking": {
      "type": "array",
      "items": { "type": "object" },
      "additionalItems": true
    },
    "translation_cache": { "type": "object" }
  },
  "additionalProperties": true,
  "$defs": {
    "request": {
      "type": "object",
      "required": [
        "language",
        "text",
        "tool_filter",
        "normalize",
        "no_cache",
        "include_cltk",
        "translation_mode"
      ],
      "properties": {
        "language": { "type": "string" },
        "text": { "type": "string" },
        "tool_filter": { "type": "string" },
        "normalize": { "type": "boolean" },
        "no_cache": { "type": "boolean" },
        "include_cltk": { "type": "boolean" },
        "translation_mode": { "type": "string" }
      },
      "additionalProperties": true
    },
    "display": {
      "type": "object",
      "required": ["header", "analysis", "meanings", "options"],
      "properties": {
        "header": { "$ref": "#/$defs/header" },
        "analysis": {
          "type": "array",
          "items": { "$ref": "#/$defs/analysisRow" }
        },
        "meanings": {
          "type": "array",
          "items": { "$ref": "#/$defs/meaningRow" }
        },
        "options": {
          "type": "object",
          "required": ["max_gloss_chars", "foster_labels", "source_details"],
          "properties": {
            "max_gloss_chars": { "type": "integer" },
            "foster_labels": { "type": "boolean" },
            "source_details": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "header": {
      "type": "object",
      "required": ["forms", "source_keys"],
      "properties": {
        "forms": { "type": "array", "items": { "type": "string" } },
        "source_keys": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "analysisRow": {
      "type": "object",
      "required": ["form", "lemma", "analysis", "source", "foster_display", "display_text"],
      "properties": {
        "form": { "type": "string" },
        "lemma": { "type": "string" },
        "analysis": { "type": "string" },
        "source": { "type": "string" },
        "foster_display": { "type": "string" },
        "display_text": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meaningRow": {
      "type": "object",
      "required": [
        "bucket_id",
        "display_gloss",
        "evidence_gloss",
        "sources",
        "source_text",
        "witness_count",
        "confidence_label",
        "source_refs",
        "source_detail_summary",
        "translation_sources",
        "source_langs",
        "entries"
      ],
      "properties": {
        "bucket_id": { "type": "string" },
        "display_gloss": { "type": "string" },
        "evidence_gloss": { "type": "string" },
        "evidence_length_note": { "type": "string" },
        "length_note": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "source_text": { "type": "string" },
        "witness_count": { "type": "integer" },
        "confidence_label": { "type": "string" },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "source_detail_summary": { "$ref": "#/$defs/sourceDetailSummary" },
        "translation_sources": { "type": "array", "items": { "type": "string" } },
        "source_langs": { "type": "array", "items": { "type": "string" } },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entrySummary" }
        }
      },
      "additionalProperties": true
    },
    "entrySummary": {
      "type": "object",
      "required": [
        "witness_id",
        "lexeme_anchor",
        "sense_anchor",
        "claim_id",
        "source_tool",
        "source_ref",
        "source_lang",
        "gloss_lang",
        "display_form",
        "source_key",
        "headword",
        "entry_id",
        "dictionary",
        "raw_blob_ref",
        "source_encoding",
        "source_entry",
        "source_detail_summary",
        "translation"
      ],
      "properties": {
        "witness_id": { "type": "string" },
        "lexeme_anchor": { "type": "string" },
        "sense_anchor": { "type": "string" },
        "claim_id": { "type": "string" },
        "source_tool": { "type": "string" },
        "source_ref": { "type": "string" },
        "source_lang": { "type": "string" },
        "gloss_lang": { "type": "string" },
        "display_form": { "type": "string" },
        "source_key": { "type": "string" },
        "headword": { "type": "string" },
        "entry_id": { "type": "string" },
        "dictionary": { "type": "string" },
        "raw_blob_ref": { "type": "string" },
        "source_encoding": { "type": "string" },
        "source_entry": { "type": "object" },
        "source_detail_summary": { "$ref": "#/$defs/sourceDetailSummary" },
        "translation": { "$ref": "#/$defs/translationSummary" }
      },
      "additionalProperties": true
    },
    "translationSummary": {
      "type": "object",
      "required": [
        "available",
        "translation_id",
        "source_lexicon",
        "source_text_lang",
        "target_lang",
        "model",
        "source_text_hash",
        "derived_from_tool",
        "derived_from_sense"
      ],
      "properties": {
        "available": { "type": "boolean" },
        "translation_id": { "type": "string" },
        "source_lexicon": { "type": "string" },
        "source_text_lang": { "type": "string" },
        "target_lang": { "type": "string" },
        "model": { "type": "string" },
        "source_text_hash": { "type": "string" },
        "derived_from_tool": { "type": "string" },
        "derived_from_sense": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sourceDetailSummary": {
      "type": "object",
      "required": ["cross_refs", "source_refs", "examples", "text"],
      "properties": {
        "cross_refs": { "type": "array", "items": { "type": "string" } },
        "source_refs": { "type": "array", "items": { "type": "string" } },
        "examples": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" }
      },
      "additionalProperties": true
    },
    "bucket": {
      "type": "object",
      "required": ["bucket_id", "normalized_gloss", "display_gloss", "witnesses"],
      "properties": {
        "bucket_id": { "type": "string" },
        "normalized_gloss": { "type": "string" },
        "display_gloss": { "type": "string" },
        "witnesses": {
          "type": "array",
          "items": { "$ref": "#/$defs/witness" }
        }
      },
      "additionalProperties": true
    },
    "witness": {
      "type": "object",
      "required": ["wsu_id", "lexeme_anchor", "sense_anchor", "gloss", "source_tool", "evidence"],
      "properties": {
        "wsu_id": { "type": "string" },
        "lexeme_anchor": { "type": "string" },
        "sense_anchor": { "type": "string" },
        "gloss": { "type": "string" },
        "source_tool": { "type": "string" },
        "evidence": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
