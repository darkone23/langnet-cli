{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langnet.local/schemas/encounter-error.v1.schema.json",
  "title": "LangNet encounter error response",
  "type": "object",
  "required": ["schema_version", "ok", "request", "error"],
  "properties": {
    "schema_version": { "const": "langnet.encounter.error.v1" },
    "ok": { "const": false },
    "request": {
      "type": "object",
      "required": [
        "language",
        "text",
        "tool_filter",
        "normalize",
        "no_cache",
        "include_cltk",
        "translation_mode"
      ],
      "properties": {
        "language": { "type": "string" },
        "text": { "type": "string" },
        "tool_filter": { "type": "string" },
        "normalize": { "type": "boolean" },
        "no_cache": { "type": "boolean" },
        "include_cltk": { "type": "boolean" },
        "translation_mode": { "type": "string" }
      },
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "required": ["code", "type", "message"],
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
